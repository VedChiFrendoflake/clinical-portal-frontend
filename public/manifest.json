{
  "id": "com.clinicalportal.app",
  "name": "Clinical Portal",
  "short_name": "CliniPort",
  "description": "A secure master clinical dashboard for tracking patient health records, lab results, and medical encounters.",
  "lang": "en",
  "dir": "ltr",
  "scope": "/",
  "start_url": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "any",
  "categories": [
    "medical",
    "health",
    "productivity"
  ],
  "theme_color": "#16c4e8",
  "background_color": "#2e45f0",
  "icons": [
    {
      "src": "/logo192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any maskable"
    },
    {
      "src": "/logo512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Patient Upload",
      "short_name": "Upload",
      "description": "Quickly upload a new PDF or scan",
      "url": "/",
      "icons": [
        {
          "src": "/logo192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/pdf": [
          ".pdf"
        ],
        "image/*": [
          ".jpg",
          ".jpeg",
          ".png"
        ]
      }
    }
  ],
  "share_target": {
    "action": "/?incoming_share=true",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "application/pdf",
            "image/*"
          ]
        }
      ]
    }
  }
}
